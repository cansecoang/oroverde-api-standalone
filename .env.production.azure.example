# ==========================================
# PRODUCCION - Variables de entorno Azure
# ==========================================
# Copia este archivo a .env.production.azure y completa los valores reales.

# Aplicacion
NODE_ENV=production
PORT=3000
APP_URL=https://tu-frontend.azurestaticapps.net
APP_NAME=Oro Verde

# Base de datos (Azure PostgreSQL)
DB_HOST=psql-oroverde-prod.postgres.database.azure.com
DB_PORT=5432
DB_USER=oroverde@psql-oroverde-prod
DB_PASS=CHANGE_ME_DB_PASSWORD
DB_NAME=control_plane
DB_LOGGING=false
DB_SYNCHRONIZE=false
DB_SSL=true

# Redis (Azure Cache for Redis / Azure Managed Redis)
REDIS_HOST=redis-oroverde-prod.northeurope.redis.azure.net
REDIS_PORT=10000
REDIS_USERNAME=default
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_TLS=true

# Seguridad
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_32_CHARS
CSRF_SECRET=CHANGE_ME_CSRF_SECRET_MIN_32_CHARS

# CORS
ALLOWED_ORIGINS=https://tu-frontend.azurestaticapps.net
CORS_ENABLED=true
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Mail
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=apikey
MAIL_PASS=CHANGE_ME_MAIL_API_KEY
MAIL_FROM="Oro Verde <noreply@oroverde.com>"

# Logging / monitoreo
LOG_LEVEL=info
APPINSIGHTS_INSTRUMENTATIONKEY=CHANGE_ME_APPINSIGHTS_KEY
