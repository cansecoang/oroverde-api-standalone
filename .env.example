# ===========================
# DATABASE (PostgreSQL)
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=root
DB_NAME=control_plane
DB_LOGGING=false
DB_SYNCHRONIZE=false

# ===========================
# REDIS
# ===========================
# docker-compose usa requirepass=R3dis_S3cure_P@ss!
# Nota: en URL, '@' debe ir codificado como '%40'
REDIS_URL=redis://:R3dis_S3cure_P%40ss!@localhost:6379

# ===========================
# SESSION
# ===========================
# ⚠️ IMPORTANTE: Cambia este secreto antes de producción
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# CSRF Protection (opcional, usa SESSION_SECRET si no se especifica)
# CSRF_SECRET=

# ===========================
# ENVIRONMENT
# ===========================
NODE_ENV=development

APP_NAME=Oro Verde
# ===========================
# APP
# ===========================
PORT=3000
APP_URL=http://localhost:4200

# ===========================
# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ===========================
# MAIL (SMTP)
# ===========================
MAIL_PORT=587
MAIL_HOST=smtp.example.com
MAIL_USER=your-email@example.com
MAIL_PASS=your-password
MAIL_FROM="No Reply <noreply@example.com>"
